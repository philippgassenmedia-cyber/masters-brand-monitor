# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Google Custom Search (Programmable Search Engine)
# Search (Gemini grounding)
SEARCH_DAILY_LIMIT=200

# Brand and rightful owner — hits on these domains are skipped,
# and Gemini gets the context so it can correctly score edge cases.
BRAND_NAME=MASTER
BRAND_OWNER=Masters Immobilien MbH
BRAND_OWN_DOMAINS=master.de
# Alle Firmennamen-Varianten des Inhabers — Hits über die eigene Firma werden
# nicht als Verletzung gewertet.
BRAND_OWNER_NAMES=Master Immobilien GmbH, Masters Immobilien GmbH

# Gemini (Google Generative AI)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# Cron endpoint protection (shared secret, set identical value in Supabase Cron headers)
CRON_SECRET=change-me-to-a-long-random-string

# DPMA-Modul: Verschlüsselungsschlüssel für IMAP-Passwörter (32 Byte hex)
ENCRYPTION_KEY=change-me-to-64-hex-chars

# Email alerts (optional, via Resend)
RESEND_API_KEY=
ALERT_EMAIL_TO=legal@masters-immobilien.example
ALERT_EMAIL_FROM=brand-monitor@masters-immobilien.example

# Gmail SMTP für automatische Scan-Reports
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
